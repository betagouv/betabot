# OpenAI-compatible API (e.g. Ollama, vLLM, LM Studio…)
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5:14b
OPENAI_EMBED_MODEL=nomic-embed-text
EMBED_DIMS=768

# Data directory
DATA_DIR=./data

# Public calendar ICS URL (used by get-data.sh and system prompt)
CALENDAR_ICS_URL=

# WelcomeKit job offers (optional — used by fetch-wttj.ts)
WELCOMEKIT_TOKEN=

# Matrix (v1)
MATRIX_HOMESERVER=https://matrix.example.org
MATRIX_USER=@betabot:example.org
MATRIX_ACCESS_TOKEN=syt_...
# MATRIX_PASSWORD=...   # alternative to access token
